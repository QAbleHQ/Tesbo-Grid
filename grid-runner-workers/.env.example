PORT=7411
EXECUTION_API_BASE_URL=http://localhost:7420
EXECUTION_API_SHARED_TOKEN=
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=bull
QUEUE_NAME=execution-jobs
QUEUE_CONCURRENCY=2
QUEUE_HEARTBEAT_MS=5000
QUEUE_JOB_TIMEOUT_MS=900000
QUEUE_MAX_RETRIES=2
PLAYWRIGHT_HEADLESS=true
START_URL_TIMEOUT_MS=60000
SCREENSHOT_DIR=./artifacts/screenshots
VIDEO_DIR=./artifacts/videos
TRACE_DIR=./artifacts/traces
RECORD_VIDEO=true
# Artifact storage: "none" (local ./artifacts volume) or "s3" (any S3-compatible
# store: AWS S3, GCS interop, MinIO, DigitalOcean Spaces).
ARTIFACT_STORAGE_PROVIDER=none
# Leave S3_ENDPOINT blank for AWS S3 (derived from region); set it for MinIO/
# Spaces/GCS. SPACES_* names are still accepted as aliases.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
# Set true for MinIO and other path-style stores; false for AWS S3 / DO Spaces.
S3_FORCE_PATH_STYLE=false
# "public-read" for directly-linkable artifacts; "" for ACL-disabled buckets.
S3_OBJECT_ACL=public-read
AGENT_SHARED_TOKEN=
WORKER_ID=
PROVIDER_LAMBDATEST_ENABLED=false
PROVIDER_BROWSERSTACK_ENABLED=false

# Middleware APM (optional but recommended)
MW_APM_SERVICE_NAME=tesbo-execution-worker
MW_APM_ACCESS_TOKEN=
# MW_API_KEY=   # Optional alias for MW_APM_ACCESS_TOKEN
# For containerized environments:
# - Docker: MW_AGENT_SERVICE=172.17.0.1
# - Docker Desktop alternative: MW_AGENT_SERVICE=host.docker.internal
# - Kubernetes: MW_AGENT_SERVICE=mw-service.mw-agent-ns.svc.cluster.local
MW_AGENT_SERVICE=
