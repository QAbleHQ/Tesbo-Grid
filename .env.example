# ─────────────────────────────────────────────────────────────────────────────
# Tesbo-Grid — Docker Compose configuration
#
# Copy to `.env` (or let `tesbo-grid init` generate it) and adjust.
# `docker compose up -d` reads this file automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Image source ─────────────────────────────────────────────────────────────
# By default the stack builds images from source. To use prebuilt public images
# instead, run `docker compose -f docker-compose.yml -f docker-compose.images.yml up -d`
# and set the registry/tag below.
TESBO_REGISTRY=ghcr.io/tesbo/tesbo-grid
TESBO_IMAGE_TAG=latest

# ── Public URLs (what the browser / external clients use) ────────────────────
# For a local single-VM trial, localhost works. In production set these to your
# real hostnames and put TLS-terminating ingress in front.
FRONTEND_URL=http://localhost:3100
BACKEND_PUBLIC_URL=http://localhost:7100
RUNNER_PUBLIC_API_URL=http://localhost:7420
SELENIUM_GRID_DOMAIN=localhost:4444

# ── Secrets ──────────────────────────────────────────────────────────────────
# Shared secret for internal service-to-service auth. Generate a strong random
# value (the setup CLI does this for you): `openssl rand -hex 32`
TESBO_INTERNAL_TOKEN=change-me-please

# Postgres password for the bundled database.
POSTGRES_PASSWORD=postgres

# ── Artifact storage (optional) ──────────────────────────────────────────────
# "none" keeps artifacts on a local volume. Set to "s3" to push to any
# S3-compatible store (AWS S3, GCS interop, MinIO, DO Spaces).
ARTIFACT_STORAGE_PROVIDER=none
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# ── Worker tuning ────────────────────────────────────────────────────────────
PLAYWRIGHT_JS_CONCURRENCY=20
PLAYWRIGHT_OTHER_CONCURRENCY=5
SELENIUM_NODE_MAX_SESSIONS=4

# ── Observability (optional) ─────────────────────────────────────────────────
MW_APM_ACCESS_TOKEN=
MW_AGENT_SERVICE=172.17.0.1
