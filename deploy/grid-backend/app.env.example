PORT=7100

# Managed PostgreSQL (same cluster, separate DB from execution)
DATABASE_URL=postgresql://user:password@db-host:25060/tesbox_execution?sslmode=require&uselibpqcompat=true

# PostgreSQL connection pool size.
# Total across ALL services must stay under the DB plan's max_connections minus 3 (reserved for superuser).
# DigitalOcean basic plan (db-s-1vcpu-1gb): 25 max → 22 usable.
# Recommended split: grid-runner-api=10, grid-backend=8 → total 18, leaving 4 for admin/monitoring.
DB_POOL_MAX=8

# Session
SESSION_DAYS=30

# Email (Postmark)
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com

# CORS — comma-separated frontend origins
CORS_ALLOWED_ORIGINS=https://app.tesbogrid.com

# Frontend URL (for links in emails)
FRONTEND_URL=https://app.tesbogrid.com

# Execution API connection
EXECUTION_API_URL=https://run.tesbogrid.com
EXECUTION_API_SHARED_TOKEN=

# TesboX API
TESBO_API_URL=https://api.tesbogrid.com

# Live VNC viewer.
# grid-backend pipes the dashboard's authenticated WebSocket to grid-selenium-proxy.
# Without these the live session screen will surface "Live viewer not configured"
# instead of streaming the running browser. Use the in-cluster service URL when
# running grid-backend inside the same Kubernetes cluster, otherwise the public
# LB hostname (e.g. https://grid.tesbogrid.com) — the proxy accepts both.
SELENIUM_PROXY_URL=http://selenium-proxy.tesbo-execution.svc.cluster.local
# Shared with grid-runner-api and grid-selenium-proxy. The proxy uses this to
# authorise the grid-backend → proxy WebSocket upgrade for live VNC.
INTERNAL_SHARED_TOKEN=

# Artifact storage (DigitalOcean Spaces / S3-compatible).
# Required for: (a) uploading test report artifacts (screenshots, traces),
# and (b) showing the recorded session video on the live session detail page
# after a test ends. The selenium-node `video-uploader` sidecar writes mp4s
# to <bucket>/selenium-sessions/<seleniumId>.mp4; grid-backend just builds
# the public URL from these vars.
ARTIFACT_STORAGE_PROVIDER=do_spaces
SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com
SPACES_REGION=blr1
SPACES_BUCKET=
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
# Optional CDN base URL — leave blank to use direct S3-style URLs.
SPACES_PUBLIC_BASE_URL=

# Middleware APM (optional)
MW_APM_SERVICE_NAME=tesbox-execute-app-api
MW_APM_ACCESS_TOKEN=
MW_AGENT_SERVICE=
