# Managed PostgreSQL connection string.
# For DigitalOcean managed PG with node-postgres, keep compatibility mode explicitly enabled.
DATABASE_URL=postgresql://user:password@db-host:25060/tesbo_execution?sslmode=require&uselibpqcompat=true

# PostgreSQL connection pool size.
# Total across ALL services must stay under the DB plan's max_connections minus 3 (reserved for superuser).
# DigitalOcean basic plan (db-s-1vcpu-1gb): 25 max → 22 usable.
# Recommended split: grid-runner-api=10, grid-backend=8 → total 18, leaving 4 for admin/monitoring.
DB_POOL_MAX=10

# Managed Redis connection string
REDIS_URL=rediss://default:password@redis-host:25061

# Queue settings
QUEUE_PREFIX=bull
QUEUE_NAME=execution-jobs

# Concurrency and limits
DEFAULT_MAX_RETRIES=2
# Per-project concurrency / queue caps were removed. The only
# customer-facing per-project cap is `maxConcurrentSessions`, set in
# the dashboard at Project → Settings → Concurrency.
DISPATCH_BATCH_SIZE=50
STALE_JOB_MINUTES=5

# Webhook
WEBHOOK_TIMEOUT_MS=10000

# Internal auth token for privileged routes (API key create/list/revoke and worker callbacks).
# Must match the token used by Tesbo backend / workers.
INTERNAL_SHARED_TOKEN=

# Middleware APM (optional but recommended)
MW_APM_SERVICE_NAME=tesbo-execution-api
MW_APM_ACCESS_TOKEN=
# MW_API_KEY=   # Optional alias for MW_APM_ACCESS_TOKEN
# For containerized deployments:
# - Docker: MW_AGENT_SERVICE=172.17.0.1
# - Docker Desktop alternative: MW_AGENT_SERVICE=host.docker.internal
# - Kubernetes: MW_AGENT_SERVICE=mw-service.mw-agent-ns.svc.cluster.local
MW_AGENT_SERVICE=
