# Tesbo Execution API configuration
PORT=7420

# PostgreSQL (execution-owned database)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tesbo_execution

# Redis (BullMQ queue)
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=bull
QUEUE_NAME=execution-jobs

# Concurrency and limits
DEFAULT_MAX_RETRIES=2
# Per-project concurrency / queue caps were removed. The only
# customer-facing per-project cap is `maxConcurrentSessions`, set in
# the dashboard at Project → Settings → Concurrency.
DISPATCH_BATCH_SIZE=50
STALE_JOB_MINUTES=5

# Autoscaling
AUTOSCALE_MIN_WORKERS=0
AUTOSCALE_MAX_WORKERS=50
AUTOSCALE_TARGET_JOBS_PER_WORKER=4
AUTOSCALE_WARM_WORKERS=0

# Webhook
WEBHOOK_TIMEOUT_MS=10000

# Tesbo platform endpoints (used for single-key auth and report links)
TESBO_API_URL=https://api.tesbogrid.com
TESBO_UI_URL=https://app.tesbogrid.com

# Middleware APM (optional but recommended)
MW_APM_SERVICE_NAME=tesbo-execution-api
MW_APM_ACCESS_TOKEN=
# MW_API_KEY=   # Optional alias for MW_APM_ACCESS_TOKEN
# For containerized environments:
# - Docker: MW_AGENT_SERVICE=172.17.0.1
# - Docker Desktop alternative: MW_AGENT_SERVICE=host.docker.internal
# - Kubernetes: MW_AGENT_SERVICE=mw-service.mw-agent-ns.svc.cluster.local
MW_AGENT_SERVICE=
